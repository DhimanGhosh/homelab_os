{
  auto_https off
}

# The install script renders the live /etc/caddy/Caddyfile using the actual FQDN.
# This file is kept only as a reference for the bundle.
https://pi-nas.taild4713b.ts.net:8444 {
  tls /etc/caddy/certs/tailscale/pi-nas.taild4713b.ts.net.crt /etc/caddy/certs/tailscale/pi-nas.taild4713b.ts.net.key
  encode gzip
  reverse_proxy 127.0.0.1:9000
}

import /etc/caddy/apps/*.caddy
