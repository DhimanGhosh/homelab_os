{
  "id": "music-player",
  "name": "Music Player",
  "version": "7.1.2",
  "category": "media",
  "entrypoint": {
    "type": "web",
    "path": "/plugins/music-player/"
  },
  "backend": {
    "framework": "flask",
    "module": "backend.app:create_app"
  },
  "ui": {
    "title": "Music Player",
    "icon": "assets/icon.png",
    "mobile_safe": true
  },
  "network": {
    "internal_port": 8140,
    "public_port": 8459,
    "proxy": true
  },
  "capabilities": [
    "filesystem.read",
    "audio.playback",
    "jobs.run"
  ],
  "healthcheck": {
    "path": "http://127.0.0.1:8140/api/health",
    "interval_seconds": 180
  },
  "lifecycle": {
    "install": "python install.py",
    "uninstall": "python uninstall.py",
    "upgrade": "python upgrade.py"
  }
}