{
  "id": "control-center",
  "name": "Control Center",
  "version": "1.7.1",
  "category": "system",
  "entrypoint": {
    "type": "web",
    "path": "/plugins/control-center/"
  },
  "backend": {
    "framework": "flask",
    "module": "backend.app:app"
  },
  "ui": {
    "title": "Control Center",
    "icon": "assets/icon.png",
    "mobile_safe": true
  },
  "network": {
    "internal_port": 9000,
    "public_port": 8444,
    "proxy": true
  },
  "capabilities": [
    "jobs.run",
    "proxy.manage",
    "docker.manage",
    "filesystem.write"
  ],
  "healthcheck": {
    "path": "http://127.0.0.1:9000/api/health",
    "interval_seconds": 90
  },
  "lifecycle": {
    "install": "python install.py",
    "uninstall": "python uninstall.py",
    "upgrade": "python upgrade.py"
  }
}