{
  "id": "personal-library",
  "name": "Personal Library",
  "version": "1.3.3",
  "category": "library",
  "entrypoint": {
    "type": "web",
    "path": "/plugins/personal-library/"
  },
  "backend": {
    "framework": "flask",
    "module": "backend.app:create_app"
  },
  "ui": {
    "title": "Personal Library",
    "icon": "assets/icon.png",
    "mobile_safe": true
  },
  "network": {
    "internal_port": 8132,
    "public_port": 8454,
    "proxy": true
  },
  "capabilities": [
    "filesystem.read",
    "filesystem.write"
  ],
  "healthcheck": {
    "path": "http://127.0.0.1:8132/api/health",
    "interval_seconds": 60
  },
  "lifecycle": {
    "install": "python install.py",
    "uninstall": "python uninstall.py",
    "upgrade": "python upgrade.py"
  }
}