{
  "id": "link-downloader",
  "name": "Media Downloader",
  "version": "1.0.9",
  "category": "media",
  "entrypoint": {
    "type": "web",
    "path": "/plugins/link-downloader/"
  },
  "backend": {
    "framework": "flask",
    "module": "backend.app:create_app"
  },
  "ui": {
    "title": "Media Downloader",
    "icon": "assets/icon.png",
    "mobile_safe": true
  },
  "network": {
    "internal_port": 8160,
    "public_port": 8460,
    "proxy": true
  },
  "capabilities": [
    "filesystem.read",
    "filesystem.write",
    "network.outbound",
    "jobs.run"
  ],
  "healthcheck": {
    "path": "http://127.0.0.1:8160/api/health",
    "interval_seconds": 180
  },
  "lifecycle": {
    "install": "python install.py",
    "uninstall": "python uninstall.py",
    "upgrade": "python upgrade.py"
  }
}