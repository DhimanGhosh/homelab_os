{
  "id": "dictionary",
  "name": "Dictionary",
  "version": "1.4.5",
  "category": "utility",
  "entrypoint": {
    "type": "web",
    "path": "/plugins/dictionary/"
  },
  "backend": {
    "framework": "flask",
    "module": "backend.app:create_app"
  },
  "ui": {
    "title": "Dictionary",
    "icon": "assets/icon.png",
    "mobile_safe": true
  },
  "network": {
    "internal_port": 8133,
    "public_port": 8455,
    "proxy": true
  },
  "capabilities": [
    "filesystem.read"
  ],
  "healthcheck": {
    "path": "http://127.0.0.1:8133/api/health",
    "interval_seconds": 30
  },
  "lifecycle": {
    "install": "python install.py",
    "uninstall": "python uninstall.py",
    "upgrade": "python upgrade.py"
  }
}