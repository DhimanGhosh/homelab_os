{
  "id": "homarr",
  "name": "Homarr",
  "version": "1.1.0",
  "category": "dashboard",
  "entrypoint": {
    "type": "web",
    "path": "/plugins/homarr/"
  },
  "backend": {
    "framework": "flask",
    "module": "backend.app:app"
  },
  "ui": {
    "title": "Homarr",
    "icon": "assets/icon.png",
    "mobile_safe": true
  },
  "network": {
    "internal_port": 7575,
    "public_port": 8453,
    "proxy": true
  },
  "capabilities": [
    "network.outbound"
  ],
  "healthcheck": {
    "path": "http://127.0.0.1:7575/",
    "interval_seconds": 30
  },
  "lifecycle": {
    "install": "python install.py",
    "uninstall": "python uninstall.py",
    "upgrade": "python upgrade.py"
  }
}