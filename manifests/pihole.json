{
  "id": "pihole",
  "name": "Pi-hole",
  "version": "1.0.0",
  "category": "network",
  "entrypoint": {
    "type": "web",
    "path": "/plugins/pihole/"
  },
  "backend": {
    "framework": "flask",
    "module": "backend.app:app"
  },
  "ui": {
    "title": "Pi-hole",
    "icon": "assets/icon.png",
    "mobile_safe": true
  },
  "network": {
    "internal_port": 8080,
    "public_port": 8447,
    "proxy": true
  },
  "capabilities": [
    "network.outbound",
    "filesystem.write"
  ],
  "healthcheck": {
    "path": "http://127.0.0.1:8080/admin/",
    "interval_seconds": 60
  },
  "lifecycle": {
    "install": "python install.py",
    "uninstall": "python uninstall.py",
    "upgrade": "python upgrade.py"
  }
}