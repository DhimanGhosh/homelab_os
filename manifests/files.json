{
  "id": "files",
  "name": "Files",
  "version": "1.3.0",
  "category": "utility",
  "entrypoint": {
    "type": "web",
    "path": "/plugins/files/"
  },
  "backend": {
    "framework": "flask",
    "module": "backend.app:app"
  },
  "ui": {
    "title": "Files",
    "icon": "assets/icon.png",
    "mobile_safe": true
  },
  "network": {
    "internal_port": 8088,
    "public_port": 8449,
    "proxy": true
  },
  "capabilities": [
    "filesystem.read",
    "filesystem.write"
  ],
  "healthcheck": {
    "path": "http://127.0.0.1:8088/",
    "interval_seconds": 30
  },
  "lifecycle": {
    "install": "python install.py",
    "uninstall": "python uninstall.py",
    "upgrade": "python upgrade.py"
  }
}