{
  "id": "api-gateway",
  "name": "API Gateway",
  "version": "1.3.0",
  "category": "api",
  "entrypoint": {
    "type": "web",
    "path": "/plugins/api-gateway/"
  },
  "backend": {
    "framework": "fastapi",
    "module": "backend.app:create_app"
  },
  "ui": {
    "title": "API Gateway",
    "icon": "assets/icon.png",
    "mobile_safe": true
  },
  "network": {
    "internal_port": 8134,
    "public_port": 8456,
    "proxy": true
  },
  "capabilities": [
    "network.outbound"
  ],
  "healthcheck": {
    "path": "http://127.0.0.1:8134/api/health",
    "interval_seconds": 30
  },
  "lifecycle": {
    "install": "python install.py",
    "uninstall": "python uninstall.py",
    "upgrade": "python upgrade.py"
  }
}