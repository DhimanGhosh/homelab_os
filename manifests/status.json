{
  "id": "status",
  "name": "Pi Status Board",
  "version": "1.3.0",
  "category": "system",
  "entrypoint": {
    "type": "web",
    "path": "/plugins/status/"
  },
  "backend": {
    "framework": "flask",
    "module": "backend.app:create_app"
  },
  "ui": {
    "title": "Pi Status Board",
    "icon": "assets/icon.png",
    "mobile_safe": true
  },
  "network": {
    "internal_port": 8131,
    "public_port": 8451,
    "proxy": true
  },
  "capabilities": [
    "system.read",
    "tailscale.read"
  ],
  "healthcheck": {
    "path": "http://127.0.0.1:8131/api/health",
    "interval_seconds": 30
  },
  "lifecycle": {
    "install": "python install.py",
    "uninstall": "python uninstall.py",
    "upgrade": "python upgrade.py"
  }
}